RUST_LOG=info

# Docker Compose 在服务器上拉取的镜像地址。
# 示例：
# APP_IMAGE=your-acr-registry.example.com/your-namespace/patrick-im:latest
APP_IMAGE=
APP_PULL_POLICY=always

# 允许访问本服务的前端 Origin，多个值可用逗号分隔。
ALLOWED_ORIGINS=
# 生产环境必须设置；如果留空，服务每次重启都会生成临时密钥，
# 之前签发的匿名 session 会全部失效。
SESSION_SECRET=
# 30 天
SESSION_TTL_SECONDS=2592000

# ICE 提供方式：
#   stun-only  -> 只返回 STUN
#   static     -> 使用 TURN_URLS / TURN_USERNAME / TURN_CREDENTIAL
#   cloudflare -> 通过 Cloudflare 生成短期 TURN 凭据
ICE_PROVIDER=stun-only
STUN_URLS=stun:stun.cloudflare.com:3478

# 自建或静态 TURN 配置
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=

# Cloudflare TURN 配置
CLOUDFLARE_TURN_KEY_ID=
CLOUDFLARE_TURN_API_TOKEN=
CLOUDFLARE_TURN_TTL_SECONDS=86400

# 浏览器通常会拒绝某些不安全的 TURN 地址；除非你很确定，
# 否则建议保持 true。
FILTER_BROWSER_UNSAFE_TURN_URLS=true
