RUST_LOG=info

# Compose image source
# APP_IMAGE is used by docker compose on the server when you deploy from a registry.
# Example:
# APP_IMAGE=your-acr-registry.example.com/your-namespace/patrick-im:latest
APP_IMAGE=
APP_PULL_POLICY=always

ALLOWED_ORIGINS=
# Required in production. If empty, the server will generate an ephemeral
# secret and all anonymous sessions will be invalidated after restart.
SESSION_SECRET=
# 30 days
SESSION_TTL_SECONDS=2592000

# ICE provider:
#   stun-only  -> only return STUN servers
#   static     -> use TURN_URLS / TURN_USERNAME / TURN_CREDENTIAL
#   cloudflare -> generate short-lived TURN credentials via Cloudflare
ICE_PROVIDER=stun-only
STUN_URLS=stun:stun.cloudflare.com:3478

# Static TURN provider settings
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=

# Cloudflare TURN provider settings
CLOUDFLARE_TURN_KEY_ID=
CLOUDFLARE_TURN_API_TOKEN=
CLOUDFLARE_TURN_TTL_SECONDS=86400

# Browsers often reject TURN URLs on port 53; keep this true unless you know
# your provider only returns browser-safe URLs.
FILTER_BROWSER_UNSAFE_TURN_URLS=true
