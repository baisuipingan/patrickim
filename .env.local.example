# 本地一键发版配置
# 复制为 .env.local 后填写。这个文件已被 Git 忽略，不会提交。

# 服务器 SSH
DEPLOY_SERVER_HOST=connect.nmb1.seetacloud.com
DEPLOY_SERVER_PORT=23421
DEPLOY_SERVER_USER=root
DEPLOY_SERVER_PASSWORD=
DEPLOY_PROJECT_DIR=/home/patrick-im

# 阿里云镜像仓库
ACR_REGISTRY=crpi-6yrxqnyn3y05zbgq.cn-qingdao.personal.cr.aliyuncs.com
IMAGE_REPO=crpi-6yrxqnyn3y05zbgq.cn-qingdao.personal.cr.aliyuncs.com/patrickcmh/patrick-im
ACR_USERNAME=百岁平安1
ACR_PASSWORD=

# 构建发布：IMAGE_TAG 留空时，默认使用当前 git 提交短 SHA，同时也会推 latest
IMAGE_TAG=
PLATFORMS=linux/amd64
RUST_TARGET=x86_64-unknown-linux-musl
PUSH_LATEST=true

# SSH 选项
SSH_STRICT_HOST_KEY_CHECKING=no
