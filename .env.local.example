# 本地一键发版配置
# 复制为 .env.local 后填写。这个文件已被 Git 忽略，不会提交。
# 这里只放“你本机发版需要的私密信息”，不要放服务运行配置。

# 服务器 SSH
DEPLOY_SERVER_HOST=your-server-ip-or-domain
DEPLOY_SERVER_PORT=22
DEPLOY_SERVER_USER=ubuntu
# 二选一：优先推荐 SSH 私钥；如果你想继续用密码，也可以留空私钥再填密码。
DEPLOY_SERVER_SSH_KEY=/absolute/path/to/your-key.pem
DEPLOY_SERVER_PASSWORD=
DEPLOY_PROJECT_DIR=/home/patrick-im

# 阿里云镜像仓库
# 如果 .env 里已经有 APP_IMAGE，这两项通常不用重复填。
ACR_REGISTRY=your-registry.example.com
IMAGE_REPO=your-registry.example.com/your-namespace/patrick-im
# 这两项可选；如果留空，脚本会直接复用当前机器 / 服务器上已保存的 docker login 状态。
ACR_USERNAME=
ACR_PASSWORD=

# 构建发布：IMAGE_TAG 留空时，默认使用当前 git 提交短 SHA，同时也会推 latest
IMAGE_TAG=
PLATFORMS=linux/amd64
RUST_TARGET=x86_64-unknown-linux-musl
PUSH_LATEST=true

# SSH 选项
SSH_STRICT_HOST_KEY_CHECKING=no
